@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AppLavaluc</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />

    <!-- Iconos -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />

    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Tu hoja de estilos personalizada -->
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>
    <!-- 🔹 NAVBAR SUPERIOR -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark sombra-navbar">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold text-uppercase" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-basket-fill text-warning"></i> AppLavaluc
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menuPrincipal">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="menuPrincipal">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index"><i class="bi bi-house-door"></i> Inicio</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Categoria" asp-action="Index"><i class="bi bi-tags"></i> Categorías</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Servicio" asp-action="Crear"><i class="bi bi-tools"></i> Servicios</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Orden" asp-action="Index"><i class="bi bi-receipt"></i> Órdenes</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Cliente" asp-action="Index"><i class="bi bi-people"></i> Clientes</a></li>
                    </ul>

                    <div class="d-flex">
                        <a class="btn btn-outline-warning me-2" asp-controller="Home" asp-action="Privacy"><i class="bi bi-info-circle"></i> Acerca</a>
                        <a class="btn btn-outline-light" href="#"><i class="bi bi-box-arrow-right"></i> Salir</a>
                    </div>
                </div>
            </div>
        </nav>
    </header>

    <!-- 🔹 CUERPO PRINCIPAL -->
    <main class="container mt-4 cuerpo-principal">
        <div class="p-4 bg-white sombra-contenedor rounded-4">
            @RenderBody()
        </div>
    </main>

    <!-- 🔹 FOOTER -->
    <footer class="text-center text-light py-3 mt-5 bg-dark sombra-footer">
        <p class="mb-0">
            <i class="bi bi-c-circle"></i> @DateTime.Now.Year - AppLavaluc |
            Desarrollado con <i class="bi bi-heart-fill text-danger"></i> en ASP.NET Core MVC
        </p>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Scripts de la vista -->
    @RenderSection("Scripts", required: false)
</body>
</html>
