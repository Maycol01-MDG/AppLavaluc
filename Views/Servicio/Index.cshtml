@model IEnumerable<AppLavaluc.Models.Servicio>

@{
    ViewData["Title"] = "Lista de Servicios";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-6">
            <h2>Servicios Disponibles</h2>
        </div>
        <div class="col-6 text-end">
            <a asp-action="Crear" class="btn btn-success"><i class="bi bi-plus-circle"></i> Nuevo Servicio</a>
        </div>
    </div>

    <br />

    @if (!Model.Any())
    {
        <div class="alert alert-info">No hay servicios registrados.</div>
    }
    else
    {
        <table class="table table-bordered table-striped">
            <thead class="table-primary">
                <tr>
                    <th>Nombre</th>
                    <th>Categoría</th>
                    <th>Precio (S/.)</th>
                    <th>Unidad</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.NombreServicio</td>
                        <td>@item.Categoria?.NombreCategoria</td>
                        <td>@item.Precio</td>
                        <td>@item.UnidadMedida</td>
                        <td>
                            <a asp-action="Editar" asp-route-id="@item.ServicioID" class="btn btn-warning btn-sm">
                                <i class="bi bi-pencil"></i> Editar
                            </a>
                            <a asp-action="Eliminar" asp-route-id="@item.ServicioID" class="btn btn-danger btn-sm">
                                <i class="bi bi-trash"></i> Eliminar
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
