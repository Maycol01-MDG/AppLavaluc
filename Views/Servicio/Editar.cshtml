@model AppLavaluc.Models.Servicio

@{
    ViewData["Title"] = "Editar Servicio";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card shadow-lg">
        <div class="card-header bg-warning text-dark">
            <h4>Editar Servicio</h4>
        </div>
        <div class="card-body">
            <form asp-action="Editar" method="post">
                <input type="hidden" asp-for="ServicioID" />

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="NombreServicio" class="form-label"></label>
                    <input asp-for="NombreServicio" class="form-control" />
                    <span asp-validation-for="NombreServicio" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CategoriaID" class="form-label">Categoría</label>
                    <select asp-for="CategoriaID" asp-items="ViewBag.Categorias" class="form-select"></select>
                </div>

                <div class="mb-3">
                    <label asp-for="Precio" class="form-label"></label>
                    <input asp-for="Precio" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="UnidadMedida" class="form-label"></label>
                    <input asp-for="UnidadMedida" class="form-control" />
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">Volver</a>
                    <button type="submit" class="btn btn-warning">Actualizar</button>
                </div>
            </form>
        </div>
    </div>
</div>
