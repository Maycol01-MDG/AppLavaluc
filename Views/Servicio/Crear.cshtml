@model AppLavaluc.Models.Servicio
@{
    ViewData["Title"] = "Crear Servicio";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="bi bi-plus-circle me-2"></i> Nuevo Servicio</h4>
            <a asp-action="Index" class="btn btn-light btn-sm">
                <i class="bi bi-arrow-left"></i> Volver
            </a>
        </div>
        <div class="card-body">
            <form asp-action="Crear" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <!-- Nombre del Servicio -->
                <div class="mb-3">
                    <label asp-for="NombreServicio" class="form-label fw-semibold"></label>
                    <input asp-for="NombreServicio" class="form-control" placeholder="Ejemplo: Lavado al seco" />
                    <span asp-validation-for="NombreServicio" class="text-danger small"></span>
                </div>

                <!-- Categoría -->
                <div class="mb-3">
                    <label asp-for="CategoriaID" class="form-label fw-semibold"></label>
                    <select asp-for="CategoriaID" asp-items="ViewBag.Categorias" class="form-select">
                        <option value="">-- Seleccione una categoría --</option>
                    </select>
                    <span asp-validation-for="CategoriaID" class="text-danger small"></span>
                </div>

                <!-- Precio -->
                <div class="mb-3">
                    <label asp-for="Precio" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <span class="input-group-text">S/.</span>
                        <input asp-for="Precio" type="number" step="0.01" min="0.01" class="form-control" placeholder="0.00" />
                    </div>
                    <span asp-validation-for="Precio" class="text-danger small"></span>
                </div>

                <!-- Unidad de Medida -->
                <div class="mb-3">
                    <label asp-for="UnidadMedida" class="form-label fw-semibold"></label>
                    <select asp-for="UnidadMedida" class="form-select">
                        <option value="">-- Seleccione unidad --</option>
                        <option value="Kilo">Kilo (kg)</option>
                        <option value="Unidad">Unidad</option>
                        <option value="Pieza">Pieza</option>
                        <option value="Docena">Docena</option>
                        <option value="Metro">Metro (m)</option>
                    </select>
                    <span asp-validation-for="UnidadMedida" class="text-danger small"></span>
                </div>

                <!-- Descripción -->
                <div class="mb-3">
                    <label asp-for="Descripcion" class="form-label fw-semibold"></label>
                    <textarea asp-for="Descripcion" class="form-control" rows="3" placeholder="Agregue una breve descripción del servicio (opcional)"></textarea>
                    <span asp-validation-for="Descripcion" class="text-danger small"></span>
                </div>

                <!-- Botones -->
                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Cancelar
                    </a>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-save"></i> Guardar Servicio
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}