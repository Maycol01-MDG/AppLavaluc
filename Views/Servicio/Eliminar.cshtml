@model AppLavaluc.Models.Servicio

@{
    ViewData["Title"] = "Eliminar Servicio";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 rounded-3">
                <div class="card-header bg-danger text-white text-center">
                    <h4><i class="bi bi-exclamation-triangle-fill"></i> Confirmar Eliminación</h4>
                </div>
                <div class="card-body text-center">
                    <p class="fs-5">
                        ¿Estás seguro que deseas eliminar el servicio
                        <strong class="text-danger">"@Model.NombreServicio"</strong>?
                    </p>
                    <p class="text-muted">
                        Esta acción no se puede deshacer.
                    </p>

                    <form asp-action="Eliminar" method="post" class="mt-4">
                        <input type="hidden" asp-for="ServicioID" />

                        <div class="d-flex justify-content-center gap-3">
                            <button type="submit" class="btn btn-danger px-4">
                                <i class="bi bi-trash"></i> Eliminar
                            </button>
                            <a asp-action="Index" class="btn btn-secondary px-4">
                                <i class="bi bi-arrow-left"></i> Cancelar
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
