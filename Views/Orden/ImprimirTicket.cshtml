@model AppLavaluc.Models.Orden
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Ticket Orden N° @Model.OrdenID</title>
    <style>
        body { font-family: Arial; font-size: 14px; }
        .ticket { width: 320px; margin: auto; border: 1px dashed #000; padding: 10px; }
        .center { text-align: center; }
        table { width: 100%; border-collapse: collapse; margin-top: 10px; }
        th, td { text-align: left; }
        hr { border: 0; border-top: 1px dashed #aaa; }
    </style>
</head>
<body onload="window.print()">
    <div class="ticket">
        <div class="center">
            <h3>🧺 LAVANDERÍA LAVALUC</h3>
            <p>Ticket N° @Model.OrdenID</p>
            <p><strong>Cliente:</strong> @Model.Cliente?.Nombre</p>
            <p><strong>Tel:</strong> @Model.Cliente?.Telefono</p>
        </div>
        <hr />
        <table>
            <thead><tr><th>Servicio</th><th>Cant</th><th>Total</th></tr></thead>
            <tbody>
            @foreach (var det in Model.Detalles)
            {
                <tr>
                    <td>@det.Servicio?.NombreServicio</td>
                    <td>@det.Cantidad</td>
                    <td>@det.Total.ToString("F2")</td>
                </tr>
            }
            </tbody>
        </table>
        <hr />
        <p><strong>Total: S/. @Model.MontoTotal.ToString("F2")</strong></p>
        <div class="center">
            <small>¡Gracias por su preferencia!</small>
        </div>
    </div>
</body>
</html>
