@model AppLavaluc.Models.Orden
@{
    ViewData["Title"] = "Editar Orden";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="text-center mt-4 mb-3">Editar Orden</h2>

<form asp-action="Editar" method="post">
    <input type="hidden" asp-for="OrdenID" />
    <partial name="~/Views/Orden/_FormPartial.cshtml" />
    <div class="text-center mt-3">
        <button type="submit" class="btn btn-warning px-4">
            <i class="bi bi-pencil"></i> Actualizar
        </button>
        <a asp-action="Index" class="btn btn-secondary px-4">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>
</form>
