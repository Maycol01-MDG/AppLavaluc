@model AppLavaluc.Models.Cliente
@{
    ViewData["Title"] = "Eliminar Cliente";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="text-center mt-4 mb-3 text-danger">Eliminar Cliente</h2>

<div class="card shadow-sm border-0 rounded-3 col-md-6 mx-auto">
    <div class="card-body text-center">
        <p>¿Seguro que deseas eliminar al cliente <strong>@Model.Nombre</strong>?</p>

        <form asp-action="Eliminar" method="post">
            <input type="hidden" asp-for="ClienteID" />
            <button type="submit" class="btn btn-danger px-4">
                <i class="bi bi-trash"></i> Eliminar
            </button>
            <a asp-action="Index" class="btn btn-secondary px-4">
                <i class="bi bi-arrow-left"></i> Cancelar
            </a>
        </form>
    </div>
</div>
