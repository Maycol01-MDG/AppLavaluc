@model AppLavaluc.Models.Cliente
@{
    ViewData["Title"] = "Detalles del Cliente";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2 class="text-center mt-4 mb-3">Detalles del Cliente</h2>

<div class="card shadow-sm border-0 rounded-3 col-md-6 mx-auto">
    <div class="card-body">
        <p><strong>Nombre:</strong> @Model.Nombre</p>
		<p><strong>Apellidos:</strong> @Model.Apellidos</p>
        <p><strong>Teléfono:</strong> @Model.Telefono</p>
        <p><strong>Email:</strong> @Model.Email</p>

        <div class="d-flex justify-content-between mt-4">
            <a asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Volver
            </a>
            <a asp-action="Editar" asp-route-id="@Model.ClienteID" class="btn btn-warning">
                <i class="bi bi-pencil-square"></i> Editar
            </a>
        </div>
    </div>
</div>
