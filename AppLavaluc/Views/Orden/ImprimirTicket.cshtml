@model AppLavaluc.Models.Orden
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Ticket #@Model.OrdenID</title>

    <style>
        /* RESET Y CONFIGURACIÓN BÁSICA */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            /* FUENTE ANCHA Y GRUESA IDEAL PARA IMPRESORAS TÉRMICAS */
            font-family: 'Verdana', 'Arial', sans-serif; 
            background: #fff;
            color: #000;
            font-size: 16px; 
            font-weight: 800; /* Todo en negrita por defecto */
        }

        /* CONTENEDOR PRINCIPAL */
        .ticket {
            width: 80mm;
            margin: 0 auto;
            padding: 10px 0;
        }

        /* UTILIDADES DE TEXTO */
        .text-center { text-align: center; }
        .text-right { text-align: right; }
        .text-left { text-align: left; }
        
        .bold { font-weight: 900; } /* Negrita máxima */
        .uppercase { text-transform: uppercase; }

        /* SEPARADORES MÁS GRUESOS */
        .dashed-line {
            border-top: 3px dashed #000; 
            margin: 15px 0;
            width: 100%;
        }

        .solid-line {
            border-top: 4px solid #000; 
            margin: 15px 0;
            width: 100%;
        }

        /* ENCABEZADO */
        .header-logo {
            font-size: 34px; 
            font-weight: 900;
            margin-bottom: 8px;
            letter-spacing: 1px;
        }

        .header-info {
            font-size: 18px; 
            margin-bottom: 5px;
        }

        /* CAJA DE INFORMACIÓN DEL CLIENTE */
        .client-box {
            border: 3px solid #000; /* Borde muy marcado */
            padding: 12px;
            border-radius: 8px;
            margin: 15px 0;
            font-size: 18px; 
            line-height: 1.5;
        }

        /* TABLA DE PRODUCTOS */
        table {
            width: 100%;
            font-size: 18px; 
            border-collapse: collapse;
        }

        th {
            text-align: left;
            border-bottom: 3px solid #000;
            padding-bottom: 10px;
            font-size: 18px;
        }

        td {
            padding: 8px 0;
            vertical-align: top;
        }

        /* SECCIÓN DE TOTALES */
        .totals-box {
            margin-top: 15px;
            font-size: 20px; 
        }

        .totals-box td {
            padding: 8px 0;
        }

        /* ESTADO DE DEUDA (VISUALMENTE IMPACTANTE) */
        .debt-alert {
            margin-top: 20px;
            border: 4px solid #000;
            padding: 15px;
            font-size: 24px; 
            font-weight: 900;
            border-radius: 10px;
        }

        .paid-badge {
            margin-top: 20px;
            border: 4px solid #000;
            padding: 15px;
            font-size: 24px; 
            font-weight: 900;
            border-radius: 20px;
        }

        /* PIE DE PÁGINA */
        .footer {
            margin-top: 30px;
            font-size: 16px; 
            text-align: center;
            line-height: 1.6;
        }

        .barcode {
            margin-top: 15px;
            height: 60px; 
            background: repeating-linear-gradient( to right, #000 0px, #000 4px, #fff 4px, #fff 8px, #000 8px, #000 12px ); 
            width: 90%;
            margin-left: 5%;
        }

        /* AJUSTES EXCLUSIVOS PARA IMPRESIÓN (MUY IMPORTANTE) */
        @@media print {
            body {
                margin: 0;
                font-size: 18pt !important; /* Letra base gigante para el papel */
                color: #000; 
            }

            .no-print {
                display: none;
            }

            .ticket {
                width: 80mm;
                margin: 0;
            }
        }

    </style>
</head>
<body onload="window.print()">

    <div class="ticket">

        <div class="text-center">
            <div class="header-logo">💧 APP LAVALUC</div>
            <div class="header-info">Av. Principal 123, Centro</div>
            <div class="header-info">Tel: (01) 999-999-999</div>
            <div class="header-info">RUC: 10123456789</div>
        </div>

        <div class="dashed-line"></div>

        <div style="display: flex; justify-content: space-between; font-size: 16px; margin: 15px 0;">
            <span>ORDEN: #@Model.OrdenID.ToString("D6")</span>
            <span>@Model.FechaRecepcion.ToString("dd/MM/yy HH:mm")</span>
        </div>

        <div class="client-box">
            <div class="bold uppercase" style="font-size: 22px;">@Model.Cliente?.NombreCompleto</div>
            <div>Tel: @(Model.Cliente?.Telefono ?? "--")</div>
            <div style="margin-top: 8px;">
                Entrega: <span class="bold">@Model.TipoEntrega</span>
            </div>
            <div>
                Fecha Est.: <span class="bold">@(Model.FechaEntregaEstimada?.ToString("dd/MM/yyyy") ?? "Por confirmar")</span>
            </div>
        </div>

        <table>
            <thead>
                <tr>
                    <th style="width: 50%;">DESCRIPCIÓN</th>
                    <th class="text-center" style="width: 20%;">CANT</th>
                    <th class="text-right" style="width: 30%;">IMPORTE</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Detalles)
                {
                    <tr>
                        <td>
                            <div class="bold" style="font-size: 18px;">@item.Servicio?.NombreServicio</div>
                            @if (item.Descuento > 0)
                            {
                                <div style="font-size: 14px; font-weight: normal;">(Desc: -@item.Descuento.ToString("0.00"))</div>
                            }
                        </td>
                        <td class="text-center" style="font-size: 20px;">@item.Cantidad</td>
                        <td class="text-right" style="font-size: 20px;">@item.Total.ToString("0.00")</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="solid-line"></div>

        <table class="totals-box">
            <tr>
                <td class="text-right">TOTAL A PAGAR:</td>
                <td class="text-right bold" style="font-size: 24px;">S/. @Model.MontoTotal.ToString("F2")</td>
            </tr>
            <tr>
                <td class="text-right">A CUENTA:</td>
                <td class="text-right" style="font-size: 22px;">S/. @Model.MontoPagado.ToString("F2")</td>
            </tr>
        </table>

        <div class="text-center">
            @if (Model.SaldoPendiente > 0)
            {
                <div class="debt-alert">
                    <div>RESTA PAGAR:</div>
                    <div style="font-size: 32px; margin: 10px 0;">S/. @Model.SaldoPendiente.ToString("F2")</div>
                    <div style="font-size: 16px; font-weight: normal;">(Pago Pendiente)</div>
                </div>
            }
            else
            {
                <div class="paid-badge">
                    ¡CANCELADO!
                    <div style="font-size: 16px; font-weight: normal; margin-top: 5px;">No existen deudas</div>
                </div>
            }
        </div>

        @if (!string.IsNullOrEmpty(Model.Observaciones))
        {
            <div style="margin-top: 25px; font-size: 16px; border: 3px dotted #000; padding: 15px;">
                <strong>NOTA:</strong> @Model.Observaciones
            </div>
        }

        <div class="footer">
            <div class="barcode"></div> 
            <p style="margin-top: 10px; font-size: 20px; font-weight: 900;">@Model.OrdenID</p>
            <br />
            <p>*** GRACIAS POR SU PREFERENCIA ***</p>
            <p>Revise sus prendas antes de retirar.</p>
            <p>No hay lugar a reclamo pasadas las 24hrs.</p>
            <p style="margin-top: 15px; font-size: 14px; font-weight: normal;">AppLavaluc System</p>
        </div>

    </div>
</body>
</html>