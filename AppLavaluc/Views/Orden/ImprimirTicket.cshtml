@model AppLavaluc.Models.Orden
@{
    Layout = null;
    var paper = ViewContext.HttpContext.Request.Query["paper"].ToString();
    var paperWidth = paper == "58" ? "58mm" : "80mm";
    var baseFontSize = paper == "58" ? "13px" : "14px";
    var qtyWidth = paper == "58" ? "8mm" : "10mm";
    var totalWidth = paper == "58" ? "16mm" : "18mm";
    var autoPrint = ViewContext.HttpContext.Request.Query["autoprint"].ToString() == "1";
    var returnUrl = ViewContext.HttpContext.Request.Query["returnUrl"].ToString();
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Ticket #@Model.OrdenID</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html, body {
            margin: 0;
            padding: 0;
            background: #ffffff;
            color: #000000;
            font-family: "Arial", "Verdana", "Tahoma", sans-serif;
            font-size: @baseFontSize;
            line-height: 1.2;
            font-variant-numeric: tabular-nums;
            font-weight: 400;
        }

        body {
            width: @paperWidth;
        }

        .no-print {
            padding: 10px;
            display: flex;
            justify-content: flex-end;
            gap: 8px;
        }

        .btn {
            border: 1px solid #000;
            background: #fff;
            color: #000;
            padding: 6px 10px;
            font-size: 12px;
            cursor: pointer;
        }

        .ticket {
            width: @paperWidth;
            padding: 2mm;
        }

        .center {
            text-align: center;
        }

        .right {
            text-align: right;
        }

        .bold {
            font-weight: 700;
        }

        .sep {
            border-top: 1px dashed #000;
            margin: 2mm 0;
        }

        .sep-solid {
            border-top: 2px solid #000;
            margin: 2mm 0;
        }

        .header-title {
            font-size: 14px;
            font-weight: 700;
        }

        .header-line {
            font-size: 11px;
            margin-top: 1mm;
        }

        .meta-row {
            display: flex;
            justify-content: space-between;
            gap: 6px;
            margin: 1mm 0;
        }

        .box {
            border: 1px solid #000;
            padding: 2mm;
            border-radius: 2mm;
        }

        .box-line {
            margin-top: 1mm;
        }

        .items-header {
            display: flex;
            gap: 6px;
            border-bottom: 1px solid #000;
            padding-bottom: 1mm;
            margin-bottom: 1mm;
        }

        .col-name {
            flex: 1 1 auto;
            min-width: 0;
        }

        .col-qty {
            width: @qtyWidth;
            text-align: center;
            flex: 0 0 auto;
        }

        .col-total {
            width: @totalWidth;
            text-align: right;
            flex: 0 0 auto;
        }

        .item {
            display: flex;
            gap: 6px;
            padding: 1mm 0;
            break-inside: avoid;
            page-break-inside: avoid;
        }

        .item-name {
            overflow-wrap: anywhere;
            word-break: break-word;
        }

        .item-subline {
            font-size: 10px;
            font-weight: 400;
        }

        .totals {
            display: flex;
            flex-direction: column;
            gap: 1mm;
        }

        .total-row {
            display: flex;
            justify-content: space-between;
            gap: 6px;
        }

        .grand-total {
            font-size: 13px;
            font-weight: 700;
        }

        .note {
            margin-top: 2mm;
            border: 1px dotted #000;
            padding: 2mm;
            overflow-wrap: anywhere;
            word-break: break-word;
        }

        .footer {
            margin-top: 3mm;
            text-align: center;
            font-size: 11px;
        }

        @@media print {
            @@page {
                size: @paperWidth auto;
                margin: 0;
            }

            html, body {
                width: @paperWidth;
                margin: 0;
                padding: 0;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }

            .no-print {
                display: none !important;
            }

            .ticket {
                width: @paperWidth;
                padding: 2mm;
            }

            tr, td, th, .item {
                break-inside: avoid;
                page-break-inside: avoid;
            }
        }

    </style>
</head>
<body>

    @if (!autoPrint)
    {
        <div class="no-print">
            <button type="button" class="btn" onclick="window.print()">Imprimir</button>
            <button type="button" class="btn" onclick="window.close()">Cerrar</button>
        </div>
    }

    <div class="ticket">

        <div class="center">
            <div class="header-title">APP LAVALUC</div>
            <div class="header-line">Av. Principal 123, Centro</div>
            <div class="header-line">Tel: (01) 999-999-999</div>
            <div class="header-line">RUC: 10123456789</div>
        </div>

        <div class="sep"></div>

        <div class="meta-row">
            <div class="bold">ORDEN: #@Model.OrdenID.ToString("D6")</div>
            <div>@Model.FechaRecepcion.ToString("dd/MM/yy HH:mm")</div>
        </div>

        <div class="box">
            <div class="bold">@Model.Cliente?.NombreCompleto</div>
            <div class="box-line">Tel: @(Model.Cliente?.Telefono ?? "--")</div>
            <div class="box-line">Entrega: <span class="bold">@Model.TipoEntrega</span></div>
            <div class="box-line">Fecha Est.: <span class="bold">@(Model.FechaEntregaEstimada?.ToString("dd/MM/yyyy") ?? "Por confirmar")</span></div>
        </div>

        <div class="items-header bold">
            <div class="col-name">DESCRIPCIÓN</div>
            <div class="col-qty">CANT</div>
            <div class="col-total">IMPORTE</div>
        </div>

        @foreach (var item in Model.Detalles)
        {
            <div class="item">
                <div class="col-name">
                    <div class="item-name">@item.Servicio?.NombreServicio</div>
                    @if (item.Descuento > 0)
                    {
                        <div class="item-subline">(Desc: -@item.Descuento.ToString("0.00"))</div>
                    }
                </div>
                <div class="col-qty">@item.Cantidad</div>
                <div class="col-total">@item.Total.ToString("0.00")</div>
            </div>
        }

        <div class="sep-solid"></div>

        <div class="totals">
            <div class="total-row grand-total">
                <div class="bold">TOTAL:</div>
                <div class="right bold">S/. @Model.MontoTotal.ToString("F2")</div>
            </div>
            <div class="total-row">
                <div>A CUENTA:</div>
                <div class="right">S/. @Model.MontoPagado.ToString("F2")</div>
            </div>
            <div class="total-row">
                <div>RESTO:</div>
                <div class="right bold">S/. @Model.SaldoPendiente.ToString("F2")</div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Observaciones))
        {
            <div class="note">
                <span class="bold">NOTA:</span> @Model.Observaciones
            </div>
        }

        <div class="footer">
            <p>*** GRACIAS POR SU PREFERENCIA ***</p>
            <p>Revise sus prendas antes de retirar.</p>
            <p>No hay lugar a reclamo pasadas las 24hrs.</p>
            <p>@Model.OrdenID</p>
        </div>

    </div>

    @if (autoPrint)
    {
        <script>
            window.addEventListener('load', () => {
                const returnUrl = @System.Text.Json.JsonSerializer.Serialize(returnUrl);
                document.body.style.visibility = 'hidden';
                window.onbeforeprint = () => {
                    document.body.style.visibility = 'visible';
                };
                window.onafterprint = () => {
                    if (returnUrl) {
                        window.location.href = returnUrl;
                    }
                };
                window.print();
            });
        </script>
    }
</body>
</html>
