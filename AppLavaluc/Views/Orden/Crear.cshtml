@model AppLavaluc.Models.Orden
@{
    ViewData["Title"] = "Crear Orden";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0"><i class="bi bi-plus-circle me-2"></i> Nueva Orden</h4>
            <a asp-action="Index" class="btn btn-light btn-sm">
                <i class="bi bi-arrow-left"></i> Volver
            </a>
        </div>

        <div class="card-body">
            <form id="formOrden" asp-action="Crear" method="post">
                <!-- VALIDACIÓN GENERAL -->
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <!-- SECCIÓN 1: DATOS DEL CLIENTE -->
                <div class="card mb-4 border-light">
                    <div class="card-header bg-light">
                        <h5 class="mb-0"><i class="bi bi-person-circle me-2"></i> Datos del Cliente</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Nombre <span class="text-danger">*</span></label>
                                <input type="text" id="nombreCliente" name="nombreCliente" class="form-control" placeholder="Ingrese nombre del cliente" required />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Apellidos <span class="text-danger">*</span></label>
                                <input type="text" id="apellidosCliente" name="apellidosCliente" class="form-control" placeholder="Ingrese apellidos" required />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Teléfono</label>
                                <input type="tel" id="telefonoCliente" name="telefonoCliente" class="form-control" placeholder="Ejemplo: 999888777" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Tipo de Entrega <span class="text-danger">*</span></label>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="TipoEntrega" id="tipoRecojo" value="Recojo" required />
                                    <label class="form-check-label" for="tipoRecojo">Recojo en tienda</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="radio" name="TipoEntrega" id="tipoDelivery" value="Delivery" />
                                    <label class="form-check-label" for="tipoDelivery">Delivery</label>
                                </div>
                            </div>

                            <div class="col-md-12 mb-3">
                                <label class="form-label fw-bold">Fecha de Entrega Estimada</label>
                                <input type="date" asp-for="FechaEntregaEstimada" class="form-control" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SECCIÓN 2: SELECCIONAR CATEGORÍA Y SERVICIOS -->
                <div class="card mb-4 border-light">
                    <div class="card-header bg-light">
                        <h5 class="mb-0"><i class="bi bi-list-check me-2"></i> Servicios Disponibles</h5>
                    </div>
                    <div class="card-body">
                        <div class="row mb-3">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Seleccionar Categoría <span class="text-danger">*</span></label>
                                <select id="selectCategoria" class="form-select" required>
                                    <option value="">-- Seleccione una categoría --</option>
                                    @if (ViewBag.Categorias != null)
                                    {
                                        @foreach (var cat in ViewBag.Categorias)
                                        {
                                            <option value="@cat.Value">@cat.Text</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Buscar Servicio</label>
                                <input type="text" id="buscarServicio" class="form-control" placeholder="Escribe para filtrar..." />
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-dark text-center">
                                    <tr>
                                        <th>Servicio</th>
                                        <th>Descripción</th>
                                        <th>Precio (S/.)</th>
                                        <th>Unidad</th>
                                        <th>Acción</th>
                                    </tr>
                                </thead>
                                <tbody id="tbodyServicios">
                                    <tr>
                                        <td colspan="5" class="text-center text-muted">Seleccione una categoría para ver servicios</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- SECCIÓN 3: DETALLES DE LA ORDEN -->
                <div class="card mb-4 border-light">
                    <div class="card-header bg-light">
                        <h5 class="mb-0"><i class="bi bi-receipt me-2"></i> Detalles de la Orden</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-bordered text-center" id="tablaDetalles">
                                <thead class="table-primary">
                                    <tr>
                                        <th>Servicio</th>
                                        <th>Cantidad</th>
                                        <th>Precio Unit.</th>
                                        <th>Descuento</th>
                                        <th>Total</th>
                                        <th>Acción</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- SECCIÓN 4: RESUMEN Y BOTONES -->
                <div class="row mb-4">
                    <div class="col-md-6"></div>
                    <div class="col-md-6">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h5 class="card-title">Total General</h5>
                                <h2 class="text-primary">
                                    S/. <span id="totalGeneral">0.00</span>
                                </h2>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- CAMPOS HIDDEN PARA ENVIAR DATOS -->
                <input type="hidden" id="hiddenServicioIds" name="servicioIds" />
                <input type="hidden" id="hiddenCantidades" name="cantidades" />
                <input type="hidden" id="hiddenDescuentos" name="descuentos" />

                <!-- BOTONES DE ACCIÓN -->
                <div class="d-flex justify-content-between gap-2">
                    <a asp-action="Index" class="btn btn-secondary btn-lg">
                        <i class="bi bi-arrow-left"></i> Cancelar
                    </a>
                    <button type="submit" class="btn btn-success btn-lg">
                        <i class="bi bi-check-circle"></i> Guardar Orden
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- MODAL PARA AGREGAR CANTIDAD Y DESCUENTO -->
<div class="modal fade" id="modalDetalle" tabindex="-1" aria-labelledby="modalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="modalLabel">
                    <i class="bi bi-plus-circle me-2"></i> Agregar Servicio
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="servicioId" />
                <input type="hidden" id="nombreServicio" />
                <input type="hidden" id="precioUnitario" />

                <div class="mb-3">
                    <label class="form-label fw-bold">Servicio Seleccionado</label>
                    <input type="text" id="nombreServicioVisible" class="form-control" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Precio Unitario (S/.)</label>
                    <input type="text" id="precioUnitarioVisible" class="form-control" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Cantidad <span class="text-danger">*</span></label>
                    <input type="number" id="cantidad" class="form-control" min="1" max="999" value="1" required />
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold">Descuento (S/.) <span class="text-muted">(opcional)</span></label>
                    <input type="number" id="descuento" class="form-control" min="0" max="9999.99" step="0.01" value="0" />
                </div>

                <div class="card bg-light">
                    <div class="card-body">
                        <h6 class="card-title">Total</h6>
                        <h4 class="text-success">
                            S/. <span id="totalModalServicio">0.00</span>
                        </h4>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-success" id="btnAgregarDetalle">
                    <i class="bi bi-check"></i> Agregar
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        let detalles = [];
        let serviciosPorCategoria = {};

        // ✅ CARGAR SERVICIOS POR CATEGORÍA AL CAMBIAR SELECT
        $("#selectCategoria").change(function () {
            const categoriaId = $(this).val();

            if (!categoriaId) {
                $("#tbodyServicios").html('<tr><td colspan="5" class="text-center text-muted">Seleccione una categoría para ver servicios</td></tr>');
                return;
            }

            // Obtener servicios del servidor
            $.ajax({
                url: '@Url.Action("ObtenerServiciosPorCategoria", "Orden")',
                type: 'GET',
                data: { categoriaId: categoriaId },
                dataType: 'json',
                success: function (data) {
                    serviciosPorCategoria = data;
                    mostrarServicios(data);
                },
                error: function () {
                    alert("Error al cargar servicios");
                }
            });
        });

        // ✅ MOSTRAR SERVICIOS EN LA TABLA
        function mostrarServicios(servicios) {
            if (servicios.length === 0) {
                $("#tbodyServicios").html('<tr><td colspan="5" class="text-center text-muted">No hay servicios en esta categoría</td></tr>');
                return;
            }

            let html = "";
            servicios.forEach(s => {
                html += `
                    <tr class="servicio-row" data-nombre="${s.nombreServicio.toLowerCase()}">
                        <td><strong>${s.nombreServicio}</strong></td>
                        <td>${s.descripcion || '-'}</td>
                        <td class="text-center fw-bold">S/. ${s.precio.toFixed(2)}</td>
                        <td class="text-center">${s.unidadMedida}</td>
                        <td class="text-center">
                            <button type="button" class="btn btn-success btn-sm agregar-servicio"
                                    data-id="${s.servicioID}"
                                    data-nombre="${s.nombreServicio}"
                                    data-precio="${s.precio}">
                                <i class="bi bi-plus-circle"></i> Agregar
                            </button>
                        </td>
                    </tr>`;
            });

            $("#tbodyServicios").html(html);
        }

        // ✅ BUSCAR SERVICIO EN LA TABLA
        $("#buscarServicio").on("keyup", function () {
            const texto = $(this).val().toLowerCase();

            $(".servicio-row").each(function () {
                const nombreServicio = $(this).data("nombre");
                if (nombreServicio.includes(texto)) {
                    $(this).show();
                } else {
                    $(this).hide();
                }
            });
        });

        // ✅ CALCULAR TOTAL EN EL MODAL
        function calcularTotalModal() {
            const precio = parseFloat($("#precioUnitario").val()) || 0;
            const cantidad = parseInt($("#cantidad").val()) || 0;
            const descuento = parseFloat($("#descuento").val()) || 0;

            const subtotal = precio * cantidad;
            const total = Math.max(0, subtotal - descuento);

            $("#totalModalServicio").text(total.toFixed(2));
        }

        // ✅ ACTUALIZAR TOTAL AL CAMBIAR CANTIDAD O DESCUENTO
        $(document).on("change", "#cantidad, #descuento", function () {
            calcularTotalModal();
        });

        $(document).on("input", "#cantidad, #descuento", function () {
            calcularTotalModal();
        });

        // ✅ ABRIR MODAL AL HACER CLIC EN AGREGAR
        $(document).on("click", ".agregar-servicio", function (e) {
            e.preventDefault();

            const servicioId = $(this).data("id");
            const nombre = $(this).data("nombre");
            const precio = parseFloat($(this).data("precio"));

            $("#servicioId").val(servicioId);
            $("#nombreServicio").val(nombre);
            $("#precioUnitario").val(precio);
            $("#nombreServicioVisible").val(nombre);
            $("#precioUnitarioVisible").val(precio.toFixed(2));
            $("#cantidad").val(1);
            $("#descuento").val(0);

            calcularTotalModal();

            const modal = new bootstrap.Modal(document.getElementById("modalDetalle"));
            modal.show();
        });

        // ✅ AGREGAR DETALLE A LA TABLA
        $("#btnAgregarDetalle").click(function () {
            const id = $("#servicioId").val();
            const nombre = $("#nombreServicio").val();
            const precio = parseFloat($("#precioUnitario").val());
            const cantidad = parseInt($("#cantidad").val());
            const descuento = parseFloat($("#descuento").val()) || 0;

            // Validaciones
            if (!id || cantidad <= 0) {
                alert("❌ La cantidad debe ser mayor a 0.");
                return;
            }

            // Calcular total
            const subtotal = precio * cantidad;
            const total = subtotal - descuento;

            // Verificar si el servicio ya existe
            const existe = detalles.find(d => d.id == id);
            if (existe) {
                alert("⚠️ Este servicio ya fue agregado.");
                return;
            }

            // Agregar detalle
            const detalle = {
                id: id,
                nombre: nombre,
                cantidad: cantidad,
                precio: precio,
                descuento: descuento,
                total: total
            };

            detalles.push(detalle);
            actualizarTabla();

            // Cerrar modal
            bootstrap.Modal.getInstance(document.getElementById("modalDetalle")).hide();
        });

        // ✅ ACTUALIZAR TABLA DE DETALLES
        function actualizarTabla() {
            let totalGeneral = 0;
            let html = "";

            detalles.forEach((d, index) => {
                totalGeneral += d.total;
                html += `
                    <tr>
                        <td class="text-start"><strong>${d.nombre}</strong></td>
                        <td>${d.cantidad}</td>
                        <td>S/. ${d.precio.toFixed(2)}</td>
                        <td>S/. ${d.descuento.toFixed(2)}</td>
                        <td class="fw-bold">S/. ${d.total.toFixed(2)}</td>
                        <td>
                            <button type="button" class="btn btn-danger btn-sm" onclick="eliminarDetalle(${index})">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>`;
            });

            if (html === "") {
                html = '<tr><td colspan="6" class="text-center text-muted">No hay servicios agregados</td></tr>';
            }

            $("#tablaDetalles tbody").html(html);
            $("#totalGeneral").text(totalGeneral.toFixed(2));
        }

        // ✅ ELIMINAR DETALLE
        function eliminarDetalle(index) {
            detalles.splice(index, 1);
            actualizarTabla();
        }

        // ✅ VALIDAR ANTES DE ENVIAR FORMULARIO
        $("#formOrden").on("submit", function (e) {
            const nombre = $("#nombreCliente").val().trim();
            const apellidos = $("#apellidosCliente").val().trim();
            const tipoEntrega = $("input[name='TipoEntrega']:checked").val();

            if (!nombre) {
                e.preventDefault();
                alert("❌ Ingrese el nombre del cliente.");
                $("#nombreCliente").focus();
                return false;
            }

            if (!apellidos) {
                e.preventDefault();
                alert("❌ Ingrese los apellidos del cliente.");
                $("#apellidosCliente").focus();
                return false;
            }

            if (!tipoEntrega) {
                e.preventDefault();
                alert("❌ Seleccione un tipo de entrega.");
                return false;
            }

            if (detalles.length === 0) {
                e.preventDefault();
                alert("❌ Debe agregar al menos un servicio a la orden.");
                return false;
            }

            // Llenar campos hidden
            let ids = detalles.map(d => d.id).join(",");
            let cantidades = detalles.map(d => d.cantidad).join(",");
            let descuentosArray = detalles.map(d => d.descuento).join(",");

            $("#hiddenServicioIds").val(ids);
            $("#hiddenCantidades").val(cantidades);
            $("#hiddenDescuentos").val(descuentosArray);

            return true;
        });

        // ✅ LIMPIAR MODAL AL CERRAR
        $("#modalDetalle").on("hide.bs.modal", function () {
            $("#servicioId").val("");
            $("#nombreServicio").val("");
            $("#precioUnitario").val("");
            $("#cantidad").val(1);
            $("#descuento").val(0);
            $("#totalModalServicio").text("0.00");
        });
    </script>
}