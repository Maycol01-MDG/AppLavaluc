@model AppLavaluc.Models.Orden
@{
    ViewData["Title"] = "Crear Orden";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4 mb-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-0"><i class="bi bi-basket2-fill me-2"></i> Nueva Orden</h2>
            <p class="text-muted mb-0">Complete los datos para registrar un nuevo servicio.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left me-2"></i> Volver al listado
        </a>
    </div>

    <form id="formOrden" asp-action="Crear" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-danger shadow-sm rounded-3 border-0" role="alert"></div>

        <div class="row g-4">

            <div class="col-lg-4">
                <div class="card shadow-sm border-0 rounded-4 h-100">
                    <div class="card-header bg-white border-0 pt-4 px-4">
                        <h5 class="fw-bold text-dark"><i class="bi bi-person-lines-fill text-primary me-2"></i> Datos del Cliente</h5>
                    </div>
                    <div class="card-body px-4 pb-4">
                        <div class="mb-3">
                            <label class="form-label small text-uppercase fw-bold text-muted">DNI/RUC</label>
                            <input type="text" id="dniCliente" name="dniCliente" class="form-control bg-light border-0" placeholder="Ej: 25485745 / 10708464100" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label small text-uppercase fw-bold text-muted">Nombres</label>
                            <input type="text" id="nombreCliente" name="nombreCliente" class="form-control bg-light border-0" placeholder="Ej: Juan Perez" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label small text-uppercase fw-bold text-muted">Apellidos</label>
                            <input type="text" id="apellidosCliente" name="apellidosCliente" class="form-control bg-light border-0" placeholder="Ej: Lopez Garcia" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label small text-uppercase fw-bold text-muted">Teléfono</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="bi bi-whatsapp text-success"></i></span>
                                <input type="tel" id="telefonoCliente" name="telefonoCliente" class="form-control bg-light border-0" placeholder="999 888 777" />
                            </div>
                        </div>

                        <hr class="my-4 text-muted opacity-25">

                        <div class="mb-3">
                            <label class="form-label small text-uppercase fw-bold text-muted">Tipo de Entrega</label>
                            <div class="d-flex gap-3">
                                <div class="form-check card-radio w-100">
                                    <input class="form-check-input" type="radio" name="tipoEntrega" id="tipoRecojo" value="Recojo en tienda" checked required>
                                    <label class="form-check-label w-100 p-2 border rounded text-center cursor-pointer" for="tipoRecojo">
                                        <i class="bi bi-shop d-block fs-4 mb-1"></i> En Tienda
                                    </label>
                                </div>
                                <div class="form-check card-radio w-100">
                                    <input class="form-check-input" type="radio" name="tipoEntrega" id="tipoDelivery" value="Delivery">
                                    <label class="form-check-label w-100 p-2 border rounded text-center cursor-pointer" for="tipoDelivery">
                                        <i class="bi bi-truck d-block fs-4 mb-1"></i> Delivery
                                    </label>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small text-uppercase fw-bold text-muted">Entrega Estimada</label>
                            <input type="date" name="fechaEntregaEstimada" class="form-control bg-light border-0" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label small text-uppercase fw-bold text-muted">Observaciones</label>
                            <textarea name="observaciones" class="form-control bg-light border-0" rows="3" placeholder="Ej: Mancha difícil en camisa..."></textarea>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-8">

                <div class="card shadow-sm border-0 rounded-4 mb-4">
                    <div class="card-header bg-white border-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold text-dark"><i class="bi bi-cart-plus-fill text-success me-2"></i> Agregar Servicios</h5>
                    </div>
                    <div class="card-body px-4">
                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <select id="selectCategoria" class="form-select form-select-lg bg-light border-0" required>
                                    <option value="">📂 Seleccionar Categoría</option>
                                    @if (ViewBag.Categorias != null)
                                    {
                                        @foreach (var cat in ViewBag.Categorias)
                                        {
                                            <option value="@cat.Value">@cat.Text</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <div class="input-group input-group-lg">
                                    <span class="input-group-text bg-light border-0"><i class="bi bi-search"></i></span>
                                    <input type="text" id="buscarServicio" class="form-control bg-light border-0" placeholder="Buscar servicio rápido..." />
                                </div>
                            </div>
                        </div>

                        <div class="border rounded-3 custom-scroll" style="height: 350px; overflow-y: auto;">
                            <table class="table table-hover mb-0 align-middle">
                                <thead class="table-light sticky-top">
                                    <tr>
                                        <th class="ps-4">Servicio</th>
                                        <th class="text-center">Precio</th>
                                        <th class="text-center">Unidad</th>
                                        <th class="text-end pe-4">Acción</th>
                                    </tr>
                                </thead>
                                <tbody id="tbodyServicios">
                                    <tr>
                                        <td colspan="4" class="text-center py-5 text-muted">
                                            <i class="bi bi-arrow-up-circle fs-1 d-block mb-2"></i>
                                            Seleccione una categoría para empezar
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                    </div>
                </div>

                <div class="card shadow-sm border-0 rounded-4">
                    <div class="card-header bg-dark text-white py-3 px-4 rounded-top-4 d-flex justify-content-between">
                        <h5 class="mb-0"><i class="bi bi-list-check me-2"></i> Resumen de Orden</h5>
                        <span class="badge bg-warning text-dark" id="badgeCantidad">0 ítems</span>
                    </div>

                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-striped mb-0 align-middle" id="tablaDetalles">
                                <thead class="text-secondary small text-uppercase">
                                    <tr>
                                        <th class="ps-4">Descripción</th>
                                        <th class="text-center">Cant.</th>
                                        <th class="text-end">P. Unit</th>
                                        <th class="text-end">Desc.</th>
                                        <th class="text-end fw-bold">Subtotal</th>
                                        <th class="text-center pe-4"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                </tbody>
                            </table>
                        </div>

                        <div class="bg-light p-4 rounded-bottom-4">
                            <div class="row align-items-end">
                                <div class="col-md-6">
                                    <label class="form-label fw-bold text-muted mb-2">💰 Registro de Pago</label>
                                    <div class="input-group input-group-lg mb-3">
                                        <span class="input-group-text bg-white border-0 fw-bold text-success">S/. A Cuenta</span>
                                        <input type="number" id="montoPagado" class="form-control border-0 fw-bold text-success" min="0" placeholder="0.00" />
                                    </div>
                                    <div class="d-flex justify-content-between text-muted small px-2">
                                        <span>Saldo Pendiente:</span>
                                        <span class="fw-bold text-danger fs-6">S/. <span id="saldoPendienteDisplay">0.00</span></span>
                                    </div>
                                </div>
                                <div class="col-md-6 text-end">
                                    <p class="text-muted mb-0 small text-uppercase fw-bold">Total a Pagar</p>
                                    <h1 class="display-4 fw-bold text-primary mb-3">S/. <span id="totalGeneralDisplay">0.00</span></h1>

                                    <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 shadow hover-scale w-100">
                                        <i class="bi bi-check-lg me-2"></i> Finalizar Orden
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <input type="hidden" id="hiddenServicioIds" name="servicioIds" />
        <input type="hidden" id="hiddenCantidades" name="cantidades" />
        <input type="hidden" id="hiddenDescuentos" name="descuentos" />
        <input type="hidden" id="hiddenMontoPagado" name="montoPagado" />
        <input type="hidden" id="hiddenSaldoPendiente" name="saldoPendiente" />
        <input type="hidden" id="hiddenEstadoPago" name="estadoPago" />
    </form>
</div>

<div class="modal fade" id="modalDetalle" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="modal-title fw-bold"><i class="bi bi-plus-lg me-2"></i> Agregar Item</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="servicioId" />
                <input type="hidden" id="precioUnitario" />

                <h5 class="fw-bold text-primary mb-1" id="nombreServicioModal">Nombre del Servicio</h5>
                <p class="text-muted small mb-4">Precio Base: S/. <span id="precioBaseModal">0.00</span></p>

                <div class="row g-3">
                    <div class="col-6">
                        <label class="form-label fw-bold">Cantidad</label>
                        <input type="number" id="cantidad" class="form-control form-control-lg bg-light border-0 text-center fw-bold" min="1" value="1" />
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-bold">Descuento (S/.)</label>
                        <input type="number" id="descuento" class="form-control form-control-lg bg-light border-0 text-center text-danger" min="0" step="0.50" value="0" />
                    </div>
                </div>

                <div class="alert alert-success mt-4 mb-0 d-flex justify-content-between align-items-center">
                    <span class="fw-bold">Total Item:</span>
                    <span class="fs-4 fw-bold">S/. <span id="totalModalServicio">0.00</span></span>
                </div>
            </div>
            <div class="modal-footer border-0 pt-0 px-4 pb-4">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary rounded-pill px-4" id="btnAgregarDetalle">
                    <i class="bi bi-check-lg me-1"></i> Agregar
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    /* Estilos extra para los Radio Buttons */
    .card-radio input:checked + label {
        background-color: #e7f1ff;
        border-color: #0d6efd !important;
        color: #0d6efd;
        font-weight: bold;
    }

    .cursor-pointer {
        cursor: pointer;
    }

    .hover-scale {
        transition: transform 0.2s;
    }

        .hover-scale:hover {
            transform: scale(1.02);
        }


    /* Barra de desplazamiento personalizada y bonita */
    .custom-scroll::-webkit-scrollbar {
        width: 8px; /* Ancho delgado */
    }

    .custom-scroll::-webkit-scrollbar-track {
        background: #f1f1f1; /* Fondo de la barra */
        border-radius: 4px;
    }

    .custom-scroll::-webkit-scrollbar-thumb {
        background: #c1c1c1; /* Color de la barra (gris suave) */
        border-radius: 4px;
    }

        .custom-scroll::-webkit-scrollbar-thumb:hover {
            background: #a8a8a8; /* Color al pasar el mouse */
        }
</style>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        let detalles = [];

        // 1. CARGAR SERVICIOS
        $("#selectCategoria").change(function () {
            const categoriaId = $(this).val();
            if (!categoriaId) {
                $("#tbodyServicios").html('<tr><td colspan="4" class="text-center py-4 text-muted">Seleccione una categoría</td></tr>');
                return;
            }
            // Muestra cargando...
            $("#tbodyServicios").html('<tr><td colspan="4" class="text-center py-4"><div class="spinner-border text-primary" role="status"></div></td></tr>');

            $.get("@Url.Action("ObtenerServiciosPorCategoria", "Orden")", { categoriaId: categoriaId }, function (response) {
                if (response.success) mostrarServicios(response.data);
            });
        });

        function mostrarServicios(servicios) {
            if (servicios.length === 0) {
                $("#tbodyServicios").html('<tr><td colspan="4" class="text-center py-4 text-muted">Sin servicios disponibles</td></tr>');
                return;
            }
            let html = servicios.map(s => `
                <tr class="servicio-row" data-nombre="${s.nombreServicio.toLowerCase()}">
                    <td class="ps-4">
                        <div class="fw-bold text-dark">${s.nombreServicio}</div>
                        <small class="text-muted">${s.descripcion || ''}</small>
                    </td>
                    <td class="fw-bold text-primary">S/. ${s.precio.toFixed(2)}</td>
                    <td><span class="badge bg-light text-dark border">${s.unidadMedida}</span></td>
                    <td class="text-end pe-4">
                        <button type="button" class="btn btn-sm btn-outline-primary rounded-circle shadow-sm agregar-servicio"
                                data-id="${s.servicioID}" data-nombre="${s.nombreServicio}" data-precio="${s.precio}">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                    </td>
                </tr>
            `).join('');
            $("#tbodyServicios").html(html);
        }

        // 2. BUSCADOR
        $("#buscarServicio").on("keyup", function () {
            const texto = $(this).val().toLowerCase();
            $(".servicio-row").toggle($(this).data("nombre").includes(texto));
        });

        // 3. MODAL Y CÁLCULOS
        function calcularTotalModal() {
            const precio = parseFloat($("#precioUnitario").val()) || 0;
            const cantidad = parseInt($("#cantidad").val()) || 0;
            const descuento = parseFloat($("#descuento").val()) || 0;
            const total = Math.max(0, (precio * cantidad) - descuento);
            $("#totalModalServicio").text(total.toFixed(2));
        }

        $(document).on("input change", "#cantidad, #descuento", calcularTotalModal);

        $(document).on("click", ".agregar-servicio", function (e) {
            $("#servicioId").val($(this).data("id"));
            $("#nombreServicioModal").text($(this).data("nombre"));
            $("#precioUnitario").val($(this).data("precio"));
            $("#precioBaseModal").text($(this).data("precio").toFixed(2));
            $("#cantidad").val(1);
            $("#descuento").val(0);
            calcularTotalModal();
            new bootstrap.Modal(document.getElementById("modalDetalle")).show();
        });

        // 4. AGREGAR A LA LISTA
        $("#btnAgregarDetalle").click(function () {
            const id = $("#servicioId").val();
            const nombre = $("#nombreServicioModal").text();
            const precio = parseFloat($("#precioUnitario").val());
            const cantidad = parseInt($("#cantidad").val());
            const descuento = parseFloat($("#descuento").val()) || 0;

            if (detalles.some(d => d.id == id)) {
                alert("⚠️ Este servicio ya está en la lista.");
                return;
            }

            const total = (precio * cantidad) - descuento;
            detalles.push({ id, nombre, cantidad, precio, descuento, total });
            actualizarTabla();
            bootstrap.Modal.getInstance(document.getElementById("modalDetalle")).hide();
        });

        // 5. ACTUALIZAR TABLA PRINCIPAL
        function actualizarTabla() {
            let html = '';
            let totalGeneral = 0;

            detalles.forEach((d, idx) => {
                totalGeneral += d.total;
                html += `
                    <tr>
                        <td class="ps-4 fw-bold text-dark">${d.nombre}</td>
                        <td class="text-center">${d.cantidad}</td>
                        <td class="text-end text-muted">S/. ${d.precio.toFixed(2)}</td>
                        <td class="text-end text-danger small">${d.descuento > 0 ? '- S/. ' + d.descuento.toFixed(2) : '-'}</td>
                        <td class="text-end fw-bold text-dark">S/. ${d.total.toFixed(2)}</td>
                        <td class="text-center pe-4">
                            <button type="button" class="btn btn-link text-danger p-0" onclick="eliminarDetalle(${idx})">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                `;
            });

            if (html === '') html = '<tr><td colspan="6" class="text-center py-4 text-muted small">No hay servicios agregados aún</td></tr>';

            $("#tablaDetalles tbody").html(html);
            $("#totalGeneralDisplay").text(totalGeneral.toFixed(2));
            $("#badgeCantidad").text(detalles.length + " ítems");

            // Recalcular saldo
            $("#montoPagado").trigger("input");
        }

        window.eliminarDetalle = function(idx) {
            detalles.splice(idx, 1);
            actualizarTabla();
        };

        // 6. CÁLCULO DE PAGO Y SALDO
        $("#montoPagado").on("input", function () {
            const total = parseFloat($("#totalGeneralDisplay").text()) || 0;
            const pagado = parseFloat($(this).val()) || 0;
            const saldo = Math.max(0, total - pagado);
            $("#saldoPendienteDisplay").text(saldo.toFixed(2));
        });

        // 7. ENVIAR FORMULARIO
        $("#formOrden").submit(function (e) {
            if (detalles.length === 0) {
                e.preventDefault();
                alert("⚠️ Debe agregar al menos un servicio para guardar la orden.");
                return;
            }

            $("#hiddenServicioIds").val(detalles.map(d => d.id).join(","));
            $("#hiddenCantidades").val(detalles.map(d => d.cantidad).join(","));
            $("#hiddenDescuentos").val(detalles.map(d => d.descuento).join(","));

            const total = parseFloat($("#totalGeneralDisplay").text());
            const pagado = parseFloat($("#montoPagado").val()) || 0;
            let estadoPago = "Pendiente";
            if (pagado > 0 && pagado < total) estadoPago = "Parcial";
            if (pagado >= total) estadoPago = "Pagado";

            $("#hiddenMontoPagado").val(pagado);
            $("#hiddenSaldoPendiente").val(total - pagado);
            $("#hiddenEstadoPago").val(estadoPago);
        });
    </script>
}