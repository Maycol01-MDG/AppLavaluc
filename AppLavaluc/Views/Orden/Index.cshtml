@model IEnumerable<AppLavaluc.Models.Orden>
@{
    ViewData["Title"] = "Órdenes";
}

<div class="container mt-4">
    <h2 class="text-primary mb-3">📋 Lista de Órdenes</h2>

    <a asp-action="Crear" class="btn btn-success mb-3">
        <i class="bi bi-plus-circle"></i> Nueva Orden
    </a>

    <table class="table table-striped table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Cliente</th>
                <th>Fecha Recepción</th>
                <th>Entrega Estimada</th>
                <th>Estado</th>
                <th>Monto Total (S/.)</th>
                <th>Tipo Entrega</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.OrdenID</td>
                    <td>@item.Cliente?.Nombre</td>
                    <td>@item.FechaRecepcion.ToShortDateString()</td>
                    <td>@item.FechaEntregaEstimada?.ToShortDateString()</td>
                    <td>@item.Estado</td>
                    <td>@item.MontoTotal.ToString("F2")</td>
                    <td>@item.TipoEntrega</td>
                    <td>
                        <a asp-action="Detalles" asp-route-id="@item.OrdenID" class="btn btn-sm btn-info">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="ImprimirTicket" asp-route-id="@item.OrdenID" target="_blank" class="btn btn-sm btn-secondary">
                            <i class="bi bi-printer"></i> Ticket
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
