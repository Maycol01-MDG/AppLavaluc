@{
    ViewData["Title"] = "Política de Privacidad";
}

<style>
    .privacy-container {
        background: #fff;
        border-radius: 15px;
        box-shadow: 0 0 40px rgba(0,0,0,0.05);
        overflow: hidden;
    }

    .privacy-header {
        background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
        color: white;
        padding: 3rem 2rem;
        text-align: center;
    }

    .section-icon {
        color: #0d6efd;
        background: #e7f1ff;
        width: 35px;
        height: 35px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        margin-right: 10px;
        font-weight: bold;
        font-size: 0.9rem;
    }

    .privacy-list li {
        margin-bottom: 0.5rem;
        position: relative;
        padding-left: 1.5rem;
    }

        .privacy-list li::before {
            content: "•";
            color: #0d6efd;
            font-weight: bold;
            position: absolute;
            left: 0;
        }
</style>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="privacy-container">

                <div class="privacy-header">
                    <i class="bi bi-shield-lock-fill fs-1 mb-2"></i>
                    <h1 class="fw-bold">Política de Privacidad</h1>
                    <p class="mb-0 opacity-75">Tu confianza es nuestra prioridad en Lavandería Lavaluc</p>
                </div>

                <div class="p-5">
                    <p class="lead text-muted mb-4">
                        En <strong>Lavandería Lavaluc</strong>, nos comprometemos a proteger la información personal que compartes con nosotros. Este documento detalla cómo manejamos tus datos.
                    </p>

                    <div class="row g-4">
                        <div class="col-md-6">
                            <h5 class="fw-bold mb-3 d-flex align-items-center">
                                <span class="section-icon">1</span> Información que recopilamos
                            </h5>
                            <ul class="list-unstyled privacy-list text-secondary">
                                <li>Nombre y apellidos del cliente.</li>
                                <li>Número de teléfono de contacto.</li>
                                <li>Historial de órdenes y servicios.</li>
                                <li>Fechas de entrega y observaciones.</li>
                            </ul>
                        </div>

                        <div class="col-md-6">
                            <h5 class="fw-bold mb-3 d-flex align-items-center">
                                <span class="section-icon">2</span> Uso de la información
                            </h5>
                            <ul class="list-unstyled privacy-list text-secondary">
                                <li>Gestión y seguimiento de órdenes.</li>
                                <li>Comunicación sobre el estado del servicio.</li>
                                <li>Emisión de comprobantes de pago.</li>
                                <li>Mejora continua de nuestros servicios.</li>
                            </ul>
                        </div>

                        <div class="col-12"><hr class="my-2 text-muted opacity-25"></div>

                        <div class="col-md-6">
                            <h5 class="fw-bold mb-3 d-flex align-items-center">
                                <span class="section-icon">3</span> Protección de Datos
                            </h5>
                            <p class="text-secondary small">
                                Implementamos medidas de seguridad técnicas para proteger tu información contra accesos no autorizados. No vendemos ni compartimos tus datos con terceros con fines comerciales.
                            </p>
                        </div>

                        <div class="col-md-6">
                            <h5 class="fw-bold mb-3 d-flex align-items-center">
                                <span class="section-icon">4</span> Tus Derechos
                            </h5>
                            <p class="text-secondary small">
                                Tienes derecho a solicitar el acceso, corrección o eliminación de tus datos de nuestra base de datos en cualquier momento contactando a administración.
                            </p>
                        </div>
                    </div>

                    <div class="mt-5 p-4 bg-light rounded-3 border-start border-4 border-primary">
                        <h5 class="fw-bold mb-2">¿Tienes dudas?</h5>
                        <p class="text-secondary mb-3">Si necesitas más información sobre cómo tratamos tus datos, contáctanos:</p>
                        <div class="d-flex gap-4 flex-wrap">
                            <a href="#" class="text-decoration-none fw-bold text-dark"><i class="bi bi-whatsapp text-success me-2"></i> 999-999-999</a>
                            <a href="#" class="text-decoration-none fw-bold text-dark"><i class="bi bi-envelope text-primary me-2"></i> contacto@lavaluc.com</a>
                        </div>
                    </div>

                    <div class="text-center mt-4">
                        <small class="text-muted fst-italic">Última actualización: @DateTime.Now.ToString("dd 'de' MMMM 'de' yyyy")</small>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>