@{
    ViewData["Title"] = "Inicio - AppLavaluc";
}

<div class="container mt-4">

    <!-- 🔵 BANNER PRINCIPAL -->
    <div class="text-center mb-4">
        <img src="~/imagenes/Inicio/lavanderia.jpeg"
             class="img-fluid rounded-4 shadow-lg"
             style="max-height: 350px; object-fit: cover; width: 100%;"
             alt="Lavandería AppLavaluc">
    </div>

    <!-- 🔵 TÍTULO PRINCIPAL -->
    <div class="text-center mb-4">
        <h1 class="fw-bold text-primary">Bienvenido a AppLavaluc</h1>
        <p class="text-secondary fs-5">Sistema moderno para la gestión de lavanderías</p>
    </div>

    <!-- 🔵 TARJETAS DE ESTADÍSTICAS -->
    <div class="row g-4">

        <!-- Clientes -->
        <div class="col-md-3">
            <div class="card shadow-lg border-0 rounded-4 text-center p-3 h-100">
                <i class="bi bi-people-fill text-primary fs-1"></i>
                <h4 class="fw-bold mt-2">Clientes</h4>
                <p class="fs-5">@ViewBag.TotalClientes</p>
            </div>
        </div>

        <!-- Órdenes -->
        <div class="col-md-3">
            <div class="card shadow-lg border-0 rounded-4 text-center p-3 h-100">
                <i class="bi bi-receipt-cutoff text-success fs-1"></i>
                <h4 class="fw-bold mt-2">Órdenes</h4>
                <p class="fs-5">@ViewBag.TotalOrdenes</p>
            </div>
        </div>

        <!-- Servicios -->
        <div class="col-md-3">
            <div class="card shadow-lg border-0 rounded-4 text-center p-3 h-100">
                <i class="bi bi-tools text-warning fs-1"></i>
                <h4 class="fw-bold mt-2">Servicios</h4>
                <p class="fs-5">@ViewBag.TotalServicios</p>
            </div>
        </div>

        <!-- Categorías -->
        <div class="col-md-3">
            <div class="card shadow-lg border-0 rounded-4 text-center p-3 h-100">
                <i class="bi bi-tags-fill text-danger fs-1"></i>
                <h4 class="fw-bold mt-2">Categorías</h4>
                <p class="fs-5">@ViewBag.TotalCategorias</p>
            </div>
        </div>

    </div>

    <!-- 🔵 ACCESOS RÁPIDOS -->
    <h3 class="mt-5 fw-bold text-secondary">Accesos rápidos</h3>

    <div class="row g-4 mt-2">

        <div class="col-md-3">
            <a asp-controller="Orden" asp-action="Crear" class="btn btn-primary w-100 p-3 rounded-4 shadow">
                <i class="bi bi-plus-circle fs-3"></i><br />
                Nueva Orden
            </a>
        </div>

        <div class="col-md-3">
            <a asp-controller="Cliente" asp-action="Crear" class="btn btn-success w-100 p-3 rounded-4 shadow">
                <i class="bi bi-person-plus fs-3"></i><br />
                Nuevo Cliente
            </a>
        </div>

        <div class="col-md-3">
            <a asp-controller="Servicio" asp-action="Crear" class="btn btn-warning w-100 p-3 rounded-4 shadow">
                <i class="bi bi-tools fs-3"></i><br />
                Nuevo Servicio
            </a>
        </div>

        <div class="col-md-3">
            <a asp-controller="Categoria" asp-action="Index" class="btn btn-danger w-100 p-3 rounded-4 shadow">
                <i class="bi bi-tags fs-3"></i><br />
                Nueva Categoría
            </a>
        </div>

    </div>

    <!-- 🔵 DESCRIPCIÓN FINAL -->
    <div class="mt-5 p-4 bg-light rounded-4 shadow-sm">
        <h4 class="fw-bold text-primary">¿Qué es AppLavaluc?</h4>
        <p class="text-secondary fs-5">
            AppLavaluc es un sistema diseñado para optimizar la gestión de lavanderías,
            permitiendo registrar órdenes, gestionar clientes, controlar servicios y
            mantener un seguimiento detallado del negocio.
        </p>
    </div>

</div>
