@model IEnumerable<AppLavaluc.Models.Usuario>

@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<h2 class="mb-4">Gestión de Usuarios</h2>

<p>
    <a asp-action="Crear" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Crear Nuevo Usuario</a>
</p>

@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">@TempData["Mensaje"]</div>
}

<table class="table table-hover">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.NombreCompleto)</th>
            <th>@Html.DisplayNameFor(model => model.NombreUsuario)</th>
            <th>@Html.DisplayNameFor(model => model.Email)</th>
            <th>@Html.DisplayNameFor(model => model.Rol)</th>
            <th>@Html.DisplayNameFor(model => model.Activo)</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.NombreCompleto</td>
                <td>@item.NombreUsuario</td>
                <td>@item.Email</td>
                <td><span class="badge bg-info text-dark">@item.Rol</span></td>
                <td>
                    @if (item.Activo)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inactivo</span>
                    }
                </td>
                <td>
                    <a asp-action="Editar" asp-route-id="@item.UsuarioID" class="btn btn-sm btn-warning"><i class="bi bi-pencil"></i> Editar</a>
                </td>
            </tr>
        }
    </tbody>
</table>
