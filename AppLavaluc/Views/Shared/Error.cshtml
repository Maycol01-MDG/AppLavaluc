@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-4 text-center">

                <div class="card-header bg-danger text-white py-3 rounded-top-4">
                    <i class="bi bi-exclamation-triangle-fill fs-1"></i>
                    <h4 class="mb-0 mt-2">¡Ups! Algo salió mal</h4>
                </div>

                <div class="card-body p-5">
                    <h5 class="card-title text-secondary mb-3">No pudimos procesar tu solicitud</h5>
                    <p class="card-text text-muted">
                        Ha ocurrido un error inesperado en el sistema. Por favor, intenta nuevamente o contacta al administrador si el problema persiste.
                    </p>

                    @if (Model.ShowRequestId)
                    {
                        <div class="alert alert-light border mt-4">
                            <small class="text-muted text-uppercase fw-bold">Código de Error (Request ID):</small><br>
                            <code class="fs-6 text-danger">@Model.RequestId</code>
                        </div>
                    }

                    <div class="mt-4">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-danger rounded-pill px-4 hover-scale">
                            <i class="bi bi-arrow-left"></i> Volver al Inicio
                        </a>
                    </div>
                </div>

                <div class="card-footer bg-light text-muted small rounded-bottom-4">
                    AppLavaluc - Sistema de Gestión
                </div>
            </div>
        </div>
    </div>
</div>